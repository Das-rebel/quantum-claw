{
  "name": "omniclaw",
  "version": "1.0.0",
  "description": "Unified AI assistant platform with multi-channel support (Alexa, WhatsApp, Telegram)",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "skills/*",
    "clients/*"
  ],
  "scripts": {
    "alexa": "node apps/alexa/alexa_handler.js",
    "alexa:dev": "node apps/alexa/alexa_handler_no_tmlpd.js",
    "test": "node test/run-tests.js",
    "test:unit": "node test/unit/*.test.js",
    "test:integration": "node test/integration/*.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
