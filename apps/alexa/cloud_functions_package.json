{
  "name": "openclaw-alexa-bridge",
  "version": "2.0.0",
  "description": "Quantum-Claw Multi-Provider Alexa Bridge - Cloud Functions Version",
  "main": "index.js",
  "dependencies": {
    "@google-cloud/functions": "^4.2.1",
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "dotenv": "^17.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "deploy": "gcloud functions deploy alexaHandler --region=us-central1 --memory=256MB --timeout=60 --max-instances=10 --allow-unauthenticated --set-env-vars=ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY,GOOGLE_API_KEY=$GOOGLE_API_KEY,PERPLEXITY_API_KEY=$PERPLEXITY_API_KEY,OPENAI_API_KEY=$OPENAI_API_KEY,CEREBRAS_API_KEY=$CEREBRAS_API_KEY,SARVAM_API_KEY=$SARVAM_API_KEY",
    "test": "gcloud functions deploy alexaHandler --region=us-central1 --memory=256MB --timeout=60 --max-instances=10 --allow-unauthenticated --set-env-vars=ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY,GOOGLE_API_KEY=$GOOGLE_API_KEY,PERPLEXITY_API_KEY=$PERPLEXITY_API_KEY,OPENAI_API_KEY=$OPENAI_API_KEY,CEREBRAS_API_KEY=$CEREBRAS_API_KEY,SARVAM_API_KEY=$SARVAM_API_KEY",
    "start-local": "node index.js",
    "logs": "gcloud functions logs read alexaHandler --region=us-central1 --limit=50"
  }
}